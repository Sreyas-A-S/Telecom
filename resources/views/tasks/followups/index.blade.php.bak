@push('scripts')
<script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.3/js/lightbox.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">

<script>
    $(document).ready(function() {
        $('.datepicker').datepicker({
            format: 'yyyy-mm-dd',
            autoclose: true
        });

        // Initialize DataTable
        var followupsTable = $('#followups-table').DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: '/tasks/{{ $task->id }}/followups/data',
                type: 'GET'
            },
            columns: [
                { data: 'id', name: 'id' },
                { data: 'notes', name: 'notes' },
                { data: 'user_name', name: 'user_name', orderable: false, searchable: false },
                { data: 'created_at', name: 'created_at' },
                { data: 'images_column', name: 'images_column', orderable: false, searchable: false },
                { data: 'action', name: 'action', orderable: false, searchable: false }
            ],
            order: [[0, 'desc']],
            responsive: true
        });

        // Map Logic
        let map;
        let userPath;
        let borderPath;
        let markers = [];

        window.initMap = function() {
            const defaultLocation = { lat: 20.5937, lng: 78.9629 };
            map = new google.maps.Map(document.getElementById("map"), {
                zoom: 5,
                center: defaultLocation,
            });

            userPath = new google.maps.Polyline({
                geodesic: true,
                strokeColor: "#27BEFF",
                strokeOpacity: 1.0,
                strokeWeight: 6,
                zIndex: 2
            });

            borderPath = new google.maps.Polyline({
                geodesic: true,
                strokeColor: "#1100FE",
                strokeOpacity: 1.0,
                strokeWeight: 8,
                zIndex: 1
            });

            userPath.setMap(map);
            borderPath.setMap(map);
            fetchAndRenderGpsData();
        };

        function fetchAndRenderGpsData() {
            const startDate = $('#map-date-start').val();
            const endDate = $('#map-date-end').val();
            const userId = @json($task->assigned_to);

            if (userId) {
                $.ajax({
                    url: `/tasks/${userId}/gps-data`,
                    method: 'GET',
                    data: { start_date: startDate, end_date: endDate },
                    success: function(gpsResponse) {
                        renderMap(gpsResponse.gpsTraces, gpsResponse.followups);
                    },
                    error: function(error) {
                        console.error('Error fetching GPS data:', error);
                    }
                });
            }
        }

        function renderMap(gpsTraces, followups) {
            userPath.setPath([]);
            borderPath.setPath([]);
            markers.forEach(marker => marker.setMap(null));
            markers = [];

            const pathCoordinates = gpsTraces.map(trace => ({
                lat: parseFloat(trace.latitude),
                lng: parseFloat(trace.longitude),
            }));

            userPath.setPath(pathCoordinates);
            borderPath.setPath(pathCoordinates);

            if (pathCoordinates.length > 0) {
                map.setCenter(pathCoordinates[0]);
                map.setZoom(12);
            }

            followups.forEach(followup => {
                if (followup.latitude && followup.longitude) {
                    const marker = new google.maps.Marker({
                        position: { lat: parseFloat(followup.latitude), lng: parseFloat(followup.longitude) },
                        map,
                        title: `Follow-up: ${followup.notes}`,
                        icon: 'http://maps.google.com/mapfiles/ms/icons/blue-dot.png'
                    });

                    const infoWindow = new google.maps.InfoWindow({
                        content: `<div><h6>Notes:</h6><p>${followup.notes}</p></div>`
                    });

                    marker.addListener("click", () => infoWindow.open(map, marker));
                    markers.push(marker);
                }
            });
        }

        $('#map-date-start, #map-date-end').on('change', fetchAndRenderGpsData);

        // View Images
        $('#followups-table').on('click', '.view-images-btn', function() {
            var images = $(this).data('images');
            var carouselInner = $('#carousel-inner-images');
            carouselInner.empty();

            if (images && images.length > 0) {
                images.forEach(function(image, index) {
                    var activeClass = index === 0 ? 'active' : '';
                    carouselInner.append(`
                        <div class="carousel-item ${activeClass}">
                            <img src="/${image}" class="d-block w-100 carousel-image" alt="Image">
                            <a href="/${image}" target="_blank" class="btn btn-light btn-sm open-image-new-tab"><i class="icon-maximize"></i></a>
                        </div>
                    `);
                });
                $('#viewImagesModal').modal('show');
            }
        });

        // Edit Follow-up
        let imagesToRemove = [];
        $('#followups-table').on('click', '.edit-followup-btn', function() {
            var id = $(this).data('id');
            imagesToRemove = [];
            $('#edit-existing-images').empty();
            $('#edit-image-preview-container').empty();

            $.get(`/tasks/{{ $task->id }}/followups/${id}/edit`, function(data) {
                $('#edit-followup-id-modal').val(data.id);
                $('#edit-followup-notes-modal').val(data.notes);
                if (data.images) {
                    data.images.forEach(img => {
                        $('#edit-existing-images').append(`
                            <div class="position-relative me-2 mb-2">
                                <img src="/${img}" class="rounded" style="width:70px; height:70px; object-fit:cover;">
                                <button type="button" class="btn btn-danger btn-sm remove-edit-image-btn" data-img="${img}" style="position:absolute; top:2px; right:2px;">&times;</button>
                            </div>
                        `);
                    });
                }
                $('#editFollowupModal').modal('show');
            });
        });

        $(document).on('click', '.remove-edit-image-btn', function() {
            imagesToRemove.push($(this).data('img'));
            $(this).parent().remove();
        });

        $('#editFollowupFormModal').on('submit', function(e) {
            e.preventDefault();
            var id = $('#edit-followup-id-modal').val();
            var fd = new FormData(this);
            imagesToRemove.forEach(img => fd.append('remove_images[]', img));

            $.ajax({
                url: `/tasks/{{ $task->id }}/followups/${id}`,
                method: 'POST',
                data: fd,
                contentType: false,
                processData: false,
                success: function() {
                    $('#editFollowupModal').modal('hide');
                    followupsTable.ajax.reload(null, false);
                    showToast('Updated successfully', 'success');
                }
            });
        });

        // Delete Follow-up
        let deleteId = null;
        $('#followups-table').on('click', '.delete-followup-btn', function() {
            deleteId = $(this).data('id');
            $('#deleteFollowupModal').modal('show');
        });

        $('#confirmDeleteFollowupBtn').on('click', function() {
            $.ajax({
                url: `/tasks/{{ $task->id }}/followups/${deleteId}`,
                method: 'DELETE',
                data: { _token: '{{ csrf_token() }}' },
                success: function() {
                    $('#deleteFollowupModal').modal('hide');
                    followupsTable.ajax.reload(null, false);
                    showToast('Deleted successfully', 'success');
                }
            });
        });

        // Add Follow-up
        $('#addFollowupFormModal').on('submit', function(e) {
            e.preventDefault();
            var fd = new FormData(this);
            $.ajax({
                url: $(this).attr('action'),
                method: 'POST',
                data: fd,
                contentType: false,
                processData: false,
                success: function() {
                    $('#addFollowupModal').modal('hide');
                    followupsTable.ajax.reload(null, false);
                    $('#addFollowupFormModal').trigger('reset');
                    $('#image-preview-container').empty();
                    showToast('Added successfully', 'success');
                }
            });
        });

        $('#followup-images-modal, #edit-followup-images-modal').on('change', function() {
            var container = $(this).attr('id') === 'followup-images-modal' ? $('#image-preview-container') : $('#edit-image-preview-container');
            container.empty();
            Array.from(this.files).forEach(file => {
                var reader = new FileReader();
                reader.onload = e => {
                    container.append(`<div class="me-2 mb-2"><img src="${e.target.result}" class="rounded" style="width:70px; height:70px; object-fit:cover;"></div>`);
                };
                reader.readAsDataURL(file);
            });
        });

        // Load Maps API
        const script = document.createElement('script');
        script.src = `https://maps.googleapis.com/maps/api/js?key={{ env('GOOGLE_MAPS_API_KEY') }}&callback=initMap`;
        script.async = true;
        document.head.appendChild(script);
    });
</script>
@endpush